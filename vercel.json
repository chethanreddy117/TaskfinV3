{
    "buildCommand": "cd frontend && npm install && npm run build",
    "outputDirectory": "frontend/.next",
    "builds": [
        {
            "src": "backend/api/**/*.py",
            "use": "@vercel/python"
        }
    ],
    "rewrites": [
        {
            "source": "/api/test",
            "destination": "/backend/api/test.py"
        },
        {
            "source": "/api/(.*)",
            "destination": "/backend/api/index.py"
        }
    ]
}